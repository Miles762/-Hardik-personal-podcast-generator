# Copy to `.env` and fill in. Never commit real secrets. Server-side only (PRD 11.3).

# ---- Postgres (used by docker-compose) ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=podcast

# ---- Backend ----
# Async SQLAlchemy URL. Inside docker-compose the host is `db`.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/podcast
CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=development

# ---- External APIs (added/used from Phase 3 onward) ----
# Required for real generation + sample.mp3; automated tests mock these.
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
